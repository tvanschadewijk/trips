{
  "name": "our-trips",
  "version": "0.7.4",
  "private": true,
  "engines": {
    "node": "22.x"
  },
  "scripts": {
    "dev": "next dev",
    "prebuild": "node scripts/generate-static-content.mjs && node scripts/ensure-claude-agent-binary.mjs",
    "build": "NEXT_TELEMETRY_DISABLED=1 next build --webpack",
    "cf:build": "npm run prebuild && opennextjs-cloudflare build",
    "cf:preview": "npm run cf:build && opennextjs-cloudflare preview",
    "cf:deploy": "npm run cf:build && wrangler deploy --keep-vars --routes \"ourtrips.to/*\" --routes \"www.ourtrips.to/*\"",
    "cf:upload": "opennextjs-cloudflare build && opennextjs-cloudflare upload",
    "cf:typegen": "wrangler types --env-interface CloudflareEnv cloudflare-env.d.ts",
    "chat:backend": "tsx node-backend/server.ts",
    "chat:backend:local": "node --env-file=.env.local --import tsx node-backend/server.ts",
    "chat:backend:deploy": "wrangler deploy --config wrangler.chat-backend.jsonc",
    "chat:backend:dry-run": "wrangler deploy --config wrangler.chat-backend.jsonc --dry-run",
    "chat:backend:worker:dry-run": "wrangler deploy --config wrangler.chat-backend.jsonc --dry-run --containers-rollout=none",
    "chat:backend:containers": "wrangler containers list --config wrangler.chat-backend.jsonc",
    "chat:backend:typecheck": "tsc -p node-backend/tsconfig.json --noEmit --pretty false",
    "chat:backend:worker:typecheck": "tsc -p node-backend/tsconfig.worker.json --noEmit --pretty false",
    "pretypecheck": "node scripts/check-local-file-hydration.mjs",
    "typecheck": "tsc -p tsconfig.build.json --noEmit --pretty false",
    "verify": "npm run lint && npm run typecheck && npm run test && npm run build",
    "start": "next start",
    "lint": "eslint",
    "test": "node --test --import tsx \"src/**/*.test.ts\"",
    "smoke:ui": "node scripts/smoke-ui-chrome.mjs",
    "stripe:setup": "node scripts/setup-stripe-billing.mjs",
    "generate:brand-video": "node scripts/generate-our-trips-brand-video.mjs",
    "compose:brand-video": "swift scripts/compose-our-trips-brand-video.swift"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.114",
    "@cloudflare/containers": "^0.3.7",
    "@googlemaps/js-api-loader": "^2.0.2",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@opennextjs/cloudflare": "^1.19.11",
    "@supabase/ssr": "^0.10.0",
    "@supabase/supabase-js": "^2.101.0",
    "bcryptjs": "^3.0.3",
    "gray-matter": "^4.0.3",
    "lucide-react": "^1.17.0",
    "marked": "^18.0.0",
    "motion": "^12.38.0",
    "next": "16.2.6",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "recharts": "^3.8.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260611.1",
    "@tailwindcss/postcss": "^4.3.1",
    "@types/bcryptjs": "^2.4.6",
    "@types/google.maps": "^3.65.0",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "tailwindcss": "^4.3.1",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "wrangler": "^4.99.0"
  }
}
