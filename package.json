{
  "name": "our-trips",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": "22.x"
  },
  "scripts": {
    "dev": "next dev",
    "prebuild": "node scripts/ensure-claude-agent-binary.mjs",
    "build": "next build",
    "typecheck": "tsc -p tsconfig.build.json --noEmit --pretty false",
    "verify": "npm run lint && npm run typecheck && npm run test && npm run build",
    "start": "next start",
    "lint": "eslint",
    "test": "node --test --import tsx \"src/**/*.test.ts\"",
    "generate:brand-video": "node scripts/generate-our-trips-brand-video.mjs",
    "compose:brand-video": "swift scripts/compose-our-trips-brand-video.swift"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.114",
    "@googlemaps/js-api-loader": "^2.0.2",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@supabase/ssr": "^0.10.0",
    "@supabase/supabase-js": "^2.101.0",
    "bcryptjs": "^3.0.3",
    "gray-matter": "^4.0.3",
    "lucide-react": "^1.17.0",
    "marked": "^18.0.0",
    "motion": "^12.38.0",
    "next": "16.2.1",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "recharts": "^3.8.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^2.4.6",
    "@types/google.maps": "^3.65.0",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.1",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5"
  }
}
