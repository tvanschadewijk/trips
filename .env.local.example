# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Unsplash (for image search API)
UNSPLASH_ACCESS_KEY=your-unsplash-access-key

# Google Maps (client-side itinerary maps)
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your-google-maps-browser-key
NEXT_PUBLIC_GOOGLE_MAPS_MAP_ID=your-google-maps-javascript-map-id

# Anthropic (admin-only in-product trip chat, via Claude Agent SDK)
# Server-side only — never import or expose in the client bundle.
ANTHROPIC_API_KEY=your-anthropic-api-key
