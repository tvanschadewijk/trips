# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Unsplash (for image search API)
UNSPLASH_ACCESS_KEY=your-unsplash-access-key

# Google Maps (client-side itinerary maps)
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your-google-maps-browser-key
NEXT_PUBLIC_GOOGLE_MAPS_MAP_ID=your-google-maps-javascript-map-id
# Optional server-side Places enrichment. Use a separate restricted server key.
GOOGLE_MAPS_SERVER_API_KEY=your-google-maps-server-key
TRIP_PLACE_ENRICHMENT_LIMIT=20

# Anthropic (admin-only in-product trip chat, via Claude Agent SDK)
# Server-side only — never import or expose in the client bundle.
ANTHROPIC_API_KEY=your-anthropic-api-key
# Optional model override. Defaults to Claude Haiku 4.5 when omitted.
TRIP_CHAT_MODEL=claude-haiku-4-5-20251001

# Stripe billing
OURTRIPS_BILLING_ENABLED=false
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-signing-secret
STRIPE_PRO_PRICE_ID=price_your-pro-monthly-price
STRIPE_EARLY_ADOPTER_PRICE_ID=price_your-early-adopter-price
OURTRIPS_PUBLIC_ORIGIN=http://localhost:3000
OURTRIPS_PRO_PRICE_LABEL=€7.95/month
OURTRIPS_EARLY_ADOPTER_PRICE_LABEL=€2,49/month
OURTRIPS_EARLY_ADOPTER_BILLING_NOTE=paid annually
OURTRIPS_PRO_MONTHLY_AMOUNT_CENTS=795
OURTRIPS_EARLY_ADOPTER_AMOUNT_CENTS=2988
